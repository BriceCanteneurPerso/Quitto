@inherits LayoutComponentBase
@inject ThemeService Theme

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary" Dense="true">
        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Class="mr-2" />
        <MudText Typo="Typo.h6">
            <MudLink Href="" Color="Color.Inherit" Underline="Underline.None">Quitto</MudLink>
        </MudText>
        <MudSpacer />
        <MudTooltip Text="@ThemeTooltip()">
            <MudIconButton Icon="@ThemeIcon()" Color="Color.Inherit"
                           OnClick="async () => await Theme.ToggleAsync()" />
        </MudTooltip>
    </MudAppBar>
    <MudMainContent>
        @* Pas de Class="pt-2" ici : MudMainContent met automatiquement padding-top:64px
           pour libérer la place sous le MudAppBar fixe, et nos utility classes MudBlazor
           passent en !important — elles écraseraient ce padding et le contenu se mettrait
           sous la barre. *@
        <div class="page-container">
            @Body
        </div>
    </MudMainContent>
</MudLayout>

@code {
    private string ThemeIcon() => Theme.Preference switch
    {
        ThemeService.Mode.Light => Icons.Material.Filled.LightMode,
        ThemeService.Mode.Dark  => Icons.Material.Filled.DarkMode,
        _                       => Icons.Material.Filled.BrightnessAuto
    };

    private string ThemeTooltip() => Theme.Preference switch
    {
        ThemeService.Mode.Light => "Thème clair (clic → sombre)",
        ThemeService.Mode.Dark  => "Thème sombre (clic → auto)",
        _                       => "Thème auto (clic → clair)"
    };
}
