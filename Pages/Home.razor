@page "/"
@inject NavigationManager Nav
@inject RecentGroupsService Recent
@inject SupabaseClient Sb
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Quitto</PageTitle>

@if (!Sb.IsConfigured)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        Supabase n'est pas configuré. Édite <code>wwwroot/appsettings.json</code> et redémarre l'app.
    </MudAlert>
}

<div class="quitto-hero">
    <h1>Mes tricounts</h1>
    <p>Répartis les frais entre amis, sans compte.</p>
    <MudStack Row="true" Spacing="2" Class="mt-4">
        <MudButton Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => Nav.NavigateTo("new"))"
                   Style="background: rgba(255,255,255,0.95); color: #1f6f54; font-weight: 700;">
            Nouveau
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.Link"
                   OnClick="OpenJoinDialog"
                   Style="border-color: rgba(255,255,255,0.7); color: white; font-weight: 600;">
            Rejoindre via lien
        </MudButton>
    </MudStack>
</div>

@if (_loading)
{
    @for (int i = 0; i < 3; i++)
    {
        <MudPaper Class="pa-3 mb-2" Elevation="0">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px" />
                <div style="flex: 1;">
                    <MudSkeleton Width="60%" Height="20px" />
                    <MudSkeleton Width="40%" Height="14px" />
                </div>
            </MudStack>
        </MudPaper>
    }
}
else if (_recent.Count == 0)
{
    <MudPaper Class="pa-6 text-center" Elevation="0" Style="background: #fafafa;">
        <MudIcon Icon="@Icons.Material.Outlined.Groups" Size="Size.Large" Color="Color.Default" Style="font-size: 56px;" />
        <MudText Class="mt-3" Typo="Typo.h6">Aucun tricount</MudText>
        <MudText Class="mt-1" Typo="Typo.body2" Color="Color.Default">
            Crée ton premier groupe ou colle le lien d'un tricount existant.
        </MudText>
    </MudPaper>
}
else
{
    @foreach (var r in _recent)
    {
        var rr = r;
        <div class="quitto-recent-card" @onclick="@(() => Nav.NavigateTo($"g/{rr.Id}"))">
            <MudAvatar Style="@($"background: {AvatarColorFor(rr.Name)}; color: white; font-weight: 700;")"
                       Size="Size.Medium">
                @InitialsOf(rr.Name)
            </MudAvatar>
            <div style="flex: 1; min-width: 0;">
                <div class="name">@rr.Name</div>
                <div class="meta">
                    @if (!string.IsNullOrEmpty(rr.Pin))
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small"
                                 Style="font-size: 12px; vertical-align: -2px; margin-right: 2px;" />
                    }
                    Vu @FormatRelative(rr.LastVisit)
                </div>
            </div>
            @* Stop propagation : on ne veut pas que le click sur "oublier"
               navigue aussi vers le tricount. *@
            <div @onclick="@(() => {})" @onclick:stopPropagation="true" style="display: inline-flex;">
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="@(() => ForgetAsync(rr))"
                               title="Oublier sur cet appareil" />
            </div>
        </div>
    }
}

@code {
    private List<RecentGroup> _recent = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _recent = await Recent.GetAllAsync();
        _loading = false;
    }

    /// <summary>
    /// Couleur déterministe à partir du nom du groupe — même tricount = même
    /// couleur d'avatar à chaque visite. Hash simple sur la palette membre.
    /// </summary>
    private static string AvatarColorFor(string name)
    {
        var sum = 0;
        foreach (var c in name ?? "")
            sum = (sum + c) % MemberPalette.Colors.Length;
        return MemberPalette.Pick(sum);
    }

    private static string InitialsOf(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant();
        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }

    private static string FormatRelative(DateTime utc)
    {
        var d = DateTime.UtcNow - utc;
        if (d.TotalMinutes < 1) return "à l'instant";
        if (d.TotalHours < 1)   return $"il y a {(int)d.TotalMinutes} min";
        if (d.TotalDays < 1)    return $"il y a {(int)d.TotalHours} h";
        if (d.TotalDays < 30)   return $"il y a {(int)d.TotalDays} j";
        return utc.ToLocalTime().ToString("dd MMM yyyy");
    }

    private async Task OpenJoinDialog()
    {
        var url = await PromptDialog.AskAsync(DialogService,
            title: "Rejoindre un tricount",
            message: "Colle le lien partagé par ton pote.",
            placeholder: "https://…/g/<id>",
            confirmLabel: "Ouvrir");
        if (string.IsNullOrWhiteSpace(url)) return;

        var seg = url.Trim().Split('/', StringSplitOptions.RemoveEmptyEntries).LastOrDefault();
        if (Guid.TryParse(seg, out var id))
        {
            Nav.NavigateTo($"g/{id}");
        }
        else
        {
            Snackbar.Add("Lien invalide.", Severity.Warning);
        }
    }

    private async Task ForgetAsync(RecentGroup r)
    {
        var ok = await ConfirmDialog.AskAsync(DialogService,
            title: "Oublier ce tricount ?",
            message: $"Le tricount « {r.Name} » sera retiré de cet appareil. Tu peux toujours le rouvrir avec son lien. " +
                     "Les données ne sont pas supprimées du serveur.",
            confirmLabel: "Oublier",
            color: Color.Warning);
        if (!ok) return;
        await Recent.ForgetAsync(r.Id);
        _recent = await Recent.GetAllAsync();
    }
}
