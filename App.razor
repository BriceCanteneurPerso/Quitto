@*
    Composant racine : pose les providers globaux (theme/popover/dialog/snackbar)
    puis monte le router. Initialise ThemeService au boot pour appliquer la prefé
    sauvegardée en localStorage avant le premier rendu de page.
*@
@implements IDisposable
@inject ThemeService Theme

<MudThemeProvider Theme="@QuittoTheme.Default" IsDarkMode="@Theme.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Quitto — 404</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <MudText Class="pa-4">Page introuvable.</MudText>
        </LayoutView>
    </NotFound>
</Router>

@code {
    protected override async Task OnInitializedAsync()
    {
        Theme.Changed += OnThemeChanged;
        await Theme.InitializeAsync();
    }

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Theme.Changed -= OnThemeChanged;
    }
}
